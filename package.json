{
  "name": "emdash-cloudflare-form",
  "version": "0.4.0",
  "description": "EmDash CMS plugin: a contact/inquiry form backend with Cloudflare Turnstile spam protection and branded HTML email notifications delivered via the native Cloudflare Email Sending Workers binding. Flexible fields, configurable branding, submission storage.",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./sandbox": {
      "import": "./dist/sandbox-entry.mjs",
      "types": "./dist/sandbox-entry.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
    "dev": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "emdash",
    "emdash-plugin",
    "cms",
    "cloudflare",
    "cloudflare-workers",
    "contact-form",
    "form",
    "turnstile",
    "email-sending"
  ],
  "license": "MIT",
  "author": "Yushi Matsui <https://github.com/tmyuu>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmyuu/emdash-cloudflare-form.git"
  },
  "bugs": {
    "url": "https://github.com/tmyuu/emdash-cloudflare-form/issues"
  },
  "homepage": "https://github.com/tmyuu/emdash-cloudflare-form#readme",
  "peerDependencies": {
    "emdash": ">=0.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "emdash": "^0.27.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
